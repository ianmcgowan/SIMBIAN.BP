*
WRITE.WORKBOOK:
  OUTPUT.FILE.NAME=OUTPUT.DIR:'/xl/workbook.xml'
  GOSUB OPEN.FILE
  L='<?xml version="1.0" encoding="utf-8"?>'
  L<-1>='<x:workbook xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:x="http://schemas.openxmlformats.org/spreadsheetml/2006/main">'
  L<-1>='  <x:fileVersion appName="Microsoft Office Excel"/>'
  L<-1>='  <x:sheets>'
  FOR FILE.IDX = 1 TO NUM.FILES
    L<-1>='    <x:sheet name="':SHEET.NAMES<FILE.IDX>:'" r:id="rId':FILE.IDX:'" sheetId="':FILE.IDX:'"/>'
  NEXT FILE.IDX
  L<-1>='  </x:sheets>'
  L<-1>='  <x:definedNames>'
  FOR FILE.IDX = 1 TO NUM.FILES
    L<-1>='    <x:definedName name="_xlnm.Print_Titles" localSheetId="':(FILE.IDX - 1):'">':SHEET.NAMES<FILE.IDX>:'!$1:$13</x:definedName>'
  NEXT FILE.IDX
  L<-1>='  </x:definedNames>'
  L<-1>='</x:workbook>'
  GOSUB WRITE.LINES
  CLOSE OUTPUT.F
RETURN
*
OPEN.FILE:
  EXECUTE '!rm -f ':OUTPUT.FILE.NAME
  EXECUTE '!touch ':OUTPUT.FILE.NAME
  OPENSEQ OUTPUT.FILE.NAME TO OUTPUT.F ELSE STOP 'CANNOT OPEN ':OUTPUT.FILE.NAME
RETURN
*
WRITE.LINES:
  FOR R=1 TO DCOUNT(L,@AM)
    LINE=L<R>
    GOSUB WRITE.LINE
  NEXT R
RETURN
*
WRITE.LINE:
  WRITESEQ LINE:CHAR(13) APPEND ON OUTPUT.F ELSE STOP 'ERROR WRITING ':FILE.NAME
RETURN
