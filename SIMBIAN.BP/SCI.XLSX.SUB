  L<-1>='            <x:name val="Times New Roman"/>'
  L<-1>='        </x:font>'
  L<-1>='        <x:font>'
  L<-1>='            <x:sz val="11"/>'
  L<-1>='            <x:name val="Calibri"/>'
  L<-1>='        </x:font>'
  L<-1>='        <x:font>'
  L<-1>='            <x:b/>'
  L<-1>='            <x:u/>'
  L<-1>='            <x:sz val="11"/>'
  L<-1>='            <x:name val="Calibri"/>'
  L<-1>='        </x:font>'
  L<-1>='    </x:fonts>'
  L<-1>='    <x:fills count="3">'
  L<-1>='        <x:fill>'
  L<-1>='            <x:patternFill patternType="none"/>'
  L<-1>='        </x:fill>'
