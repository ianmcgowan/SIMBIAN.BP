  L<-1>='        <x:xf borderId="0" fillId="0" fontId="0" numFmtId="0"/>'
  L<-1>='    </x:cellStyleXfs>'
  L<-1>='    <x:cellXfs count="13">'
  L<-1>='        <x:xf applyNumberFormat="1" borderId="0" fillId="0" fontId="0" numFmtId="164" xfId="0" applyAlignment="1"><x:alignment horizontal="right"/></x:xf>'
  L<-1>='        <x:xf applyNumberFormat="1" borderId="0" fillId="0" fontId="0" numFmtId="165" xfId="0" applyAlignment="1"><x:alignment horizontal="right"/></x:xf>'
  L<-1>='        <x:xf applyNumberFormat="1" borderId="0" fillId="0" fontId="0" numFmtId="166" xfId="0" applyAlignment="1"><x:alignment horizontal="right"/></x:xf>'
