***************************************************************************
* Program: SCI.XLSX.SUB.TEST
* Comment: Unit tests for single-sheet and multi-sheet XLSX generation.
***************************************************************************
* Test Case 1: Single Sheet Generation (Backward Compatibility Check)
INPUT.FILE.NAME='input'
OSWRITE "" ON INPUT.FILE.NAME
OPENSEQ INPUT.FILE.NAME TO INPUT.F ELSE STOP 'CANNOT OPEN ':INPUT.FILE.NAME
LINE="Name":@VM:"Value"
WRITESEQ LINE APPEND ON INPUT.F ELSE STOP 'ERROR WRITING ':INPUT.FILE.NAME
LINE="Fred Flintstone":@VM:"50"
WRITESEQ LINE ON INPUT.F ELSE STOP 'ERROR WRITING ':INPUT.FILE.NAME
CLOSESEQ INPUT.F
STYLES=""
FORMATS=""
OUTPUT.FILE.NAME="output"
*
CALL SCI.XLSX.SUB(INPUT.FILE.NAME, STYLES, FORMATS, OUTPUT.FILE.NAME)
PRINT OUTPUT.FILE.NAME:' created'
*
* Test Case 2: Multi-Sheet Generation (New Array Feature Check)
FILE1 = 'input1'
OSWRITE "" ON FILE1
OPENSEQ FILE1 TO F1 ELSE STOP 'CANNOT OPEN ':FILE1
WRITESEQ "Product":@VM:"Sales" APPEND ON F1 ELSE STOP 'ERROR WRITING ':FILE1
WRITESEQ "Widget A":@VM:"100" ON F1 ELSE STOP 'ERROR WRITING ':FILE1
WRITESEQ "Widget B":@VM:"200" ON F1 ELSE STOP 'ERROR WRITING ':FILE1
CLOSESEQ F1
*
FILE2 = 'input2'
OSWRITE "" ON FILE2
OPENSEQ FILE2 TO F2 ELSE STOP 'CANNOT OPEN ':FILE2
WRITESEQ "Department":@VM:"Budget" APPEND ON F2 ELSE STOP 'ERROR WRITING ':FILE2
WRITESEQ "R&D":@VM:"5000" ON F2 ELSE STOP 'ERROR WRITING ':FILE2
WRITESEQ "Marketing":@VM:"12000" ON F2 ELSE STOP 'ERROR WRITING ':FILE2
CLOSESEQ F2
*
FILE3 = 'input_special_\?*[]:'
OSWRITE "" ON FILE3
OPENSEQ FILE3 TO F3 ELSE STOP 'CANNOT OPEN ':FILE3
WRITESEQ "Special":@VM:"Data" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
CLOSESEQ F3
*
FILE4 = 'input_very_long_sheet_name_that_exceeds_thirty_one_characters'
OSWRITE "" ON FILE4
OPENSEQ FILE4 TO F4 ELSE STOP 'CANNOT OPEN ':FILE4
WRITESEQ "Long":@VM:"Name" APPEND ON F4 ELSE STOP 'ERROR WRITING ':FILE4
CLOSESEQ F4
*
FILE5 = 'input1.csv'
OSWRITE "" ON FILE5
OPENSEQ FILE5 TO F5 ELSE STOP 'CANNOT OPEN ':FILE5
WRITESEQ "Dup":@VM:"Base" APPEND ON F5 ELSE STOP 'ERROR WRITING ':FILE5
CLOSESEQ F5
*
FILE6 = 'input_very_long_sheet_name_that_exceeds_thirty_one_characters_again'
OSWRITE "" ON FILE6
OPENSEQ FILE6 TO F6 ELSE STOP 'CANNOT OPEN ':FILE6
WRITESEQ "DupLong":@VM:"Name" APPEND ON F6 ELSE STOP 'ERROR WRITING ':FILE6
CLOSESEQ F6
*
FILE7 = '.csv'
OSWRITE "" ON FILE7
OPENSEQ FILE7 TO F7 ELSE STOP 'CANNOT OPEN ':FILE7
WRITESEQ "Empty":@VM:"Fallback" APPEND ON F7 ELSE STOP 'ERROR WRITING ':FILE7
CLOSESEQ F7
*
INPUT.FILES = FILE1 : @AM : FILE2 : @AM : FILE3 : @AM : FILE4 : @AM : FILE5 : @AM : FILE6 : @AM : FILE7
*
* Set up 3D Styles and Formats
M.STYLES = ""
M.FORMATS = ""
*
OUTPUT.MULTI = "multi_output"
CALL SCI.XLSX.SUB(INPUT.FILES, M.STYLES, M.FORMATS, OUTPUT.MULTI)
PRINT OUTPUT.MULTI:' created'
*
* Test Case 3: Formatting Test (Dates & Numbers)
FILE3 = 'input_fmt'
OSWRITE "" ON FILE3
OPENSEQ FILE3 TO F3 ELSE STOP 'CANNOT OPEN ':FILE3
* Row 1 (Header)
WRITESEQ "Label":@VM:"Value" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 2: U2 Base Date
WRITESEQ "U2 Base Date 0 (12/31/1967)":@VM:"12/31/1967" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 3: Date in 1900s
WRITESEQ "Date in 1900s (01/01/1900)":@VM:"01/01/1900" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 4: Date in 1900s
WRITESEQ "Date in 1900s (12/31/1900)":@VM:"12/31/1900" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 5: Date in 2000s
WRITESEQ "Date in 2000s (06/17/2026)":@VM:"06/17/2026" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 6: Date in 2100s
WRITESEQ "Date in 2100s (01/01/2100)":@VM:"01/01/2100" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 7: Date in 2100s
WRITESEQ "Date in 2100s (12/31/2100)":@VM:"12/31/2100" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 8: Custom style date (DD/MM/YYYY)
WRITESEQ "DD/MM/YYYY Style Date":@VM:"12/31/1967" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 9: Invalid date fallback
WRITESEQ "Invalid Date String":@VM:"not-a-date" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 10: Euro invalid date fallback
WRITESEQ "Euro date format (31/12/2026)":@VM:"31/12/2026" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 11: Standard Float
WRITESEQ "Positive Float 2 Dec (1,234.56)":@VM:"1,234.56" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 12: Trailing Minus
WRITESEQ "Trailing Minus (123.45-)":@VM:"123.45-" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 13: Parentheses Negative
WRITESEQ "Parentheses Negative ((500.00))":@VM:"(500.00)" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 14: Four Decimals
WRITESEQ "Four Decimals (0.1234)":@VM:"0.1234" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 15: Empty value
WRITESEQ "Empty Value":@VM:"" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 16: String starting with +
WRITESEQ "Text starting with + (+1234)":@VM:"+1234" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
* Row 17: XML characters
WRITESEQ "Special XML characters (<>&)":@VM:"Left & Right <Inside>" APPEND ON F3 ELSE STOP 'ERROR WRITING ':FILE3
CLOSESEQ F3
*
FMT.STYLES = ""
FMT.FORMATS = ""
*
* Formats (Row, Column) - Note: UniBasic indices are 1-based.
* Row 2
FMT.FORMATS<2, 2> = "D4/"
* Row 3
FMT.FORMATS<3, 2> = "D4/"
* Row 4
FMT.FORMATS<4, 2> = "D4/"
* Row 5
FMT.FORMATS<5, 2> = "D4/"
* Row 6
FMT.FORMATS<6, 2> = "D4/"
* Row 7
FMT.FORMATS<7, 2> = "D4/"
* Row 8: Use format D4/ and style 0 (dd/mm/yyyy)
FMT.FORMATS<8, 2> = "D4/"
FMT.STYLES<8, 2> = "0"
* Row 9
FMT.FORMATS<9, 2> = "D4/"
* Row 10
FMT.FORMATS<10, 2> = "D4/"
* Row 11
FMT.FORMATS<11, 2> = "MD2"
* Row 12
FMT.FORMATS<12, 2> = "MD2"
* Row 13
FMT.FORMATS<13, 2> = "MD2"
* Row 14
FMT.FORMATS<14, 2> = "MD4"
* Row 15
FMT.FORMATS<15, 2> = "MD2"
*
OUTPUT.FMT = "fmt_output"
CALL SCI.XLSX.SUB(FILE3, FMT.STYLES, FMT.FORMATS, OUTPUT.FMT)
PRINT OUTPUT.FMT:' created'
*
